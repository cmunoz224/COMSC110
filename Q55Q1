#include <iostream>
using namespace std;

int main() {
    int N, M;

    cout << "Enter your base number: ";
    cin >> N;

    cout << "Enter your exponent: ";
    cin >> M;

    int result = 1;

    cout << N << " to power number: ";

    for (int i = 0; i <= M; i++) {
        if (i > 0) {
            result = result * N;
        }

        cout << result;

        if (i < M) {
            cout << ", ";
        }
    }

    return 0;
}
